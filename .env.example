# Einfachster Weg: NICHT von Hand ausfuellen, sondern den Assistenten nutzen:
#   bash scripts/setup-env.sh
# Alternativ: kopieren nach ".env" und Werte anpassen. ".env" NIEMALS committen.

# Zeitzone aller Container
TZ=Europe/Berlin

# Heimnetz-CIDR fuer Firewall-Regeln (an eigenes LAN anpassen!)
LAN_SUBNET=192.168.1.0/24

# Feste IP des Pi im LAN (DHCP-Reservierung im Router einrichten)
PI_STATIC_IP=192.168.1.10

# Host-Ports (nur LAN-Bindung, siehe docker-compose.yml)
PORT_PIHOLE_UI=8080
PORT_DNS=53
PORT_UPTIME=3001

# Oeffentliche Domain der Webseite (ueber Cloudflare verwaltet)
DOMAIN=<<DOMAIN>>

# Pi-hole Admin-Passwort (Secret)
PIHOLE_PASSWORD=<<PIHOLE_PASSWORD>>

# Cloudflare Tunnel Token aus dem Zero-Trust-Dashboard (Secret)
CLOUDFLARE_TUNNEL_TOKEN=<<CLOUDFLARE_TUNNEL_TOKEN>>

# --- Backup (Abschnitt 8 der SPEC) ---

# rclone-Remote-Ziel fuer verschluesselte Backups (vorher: rclone config)
BACKUP_REMOTE=onedrive:PiBackups

# Aufbewahrung
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4

# age-Public-Key (Empfaenger) zum Verschluesseln der Backups.
# Erzeugen mit: age-keygen -o ~/.config/age/pi-server.txt
# Dort steht "Public key: age1..." -> hier eintragen.
# Der PRIVATE Key bleibt ausserhalb von Git/Backup an einem sicheren Ort!
AGE_RECIPIENT=<<AGE_RECIPIENT_PUBLIC_KEY>>
